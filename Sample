#### 4. javascript.html (Frontend Logic)
```html
<script>
    document.getElementById('auditForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const form = e.target;
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.innerText = "Processing...";

        const fileFields = ['reportFile', 'carFile', 'fiveWhyFile'];
        const uploads = {};
        
        // อ่านไฟล์เป็น Base64
        const readFiles = fileFields.map(id => {
            return new Promise((resolve) => {
                const file = document.getElementById(id).files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = (e) => resolve({id: id, data: e.target.result});
                    reader.readAsDataURL(file);
                } else {
                    resolve({id: id, data: ""});
                }
            });
        });

        Promise.all(readFiles).then(results => {
            const formData = {
                auditDate: form.auditDate.value,
                plant: form.plant.value,
                dept: form.dept.value,
                detail: form.detail.value,
                finding: Array.from(form.finding.selectedOptions).map(o => o.value),
                carDetail: form.carDetail.value,
                fiveWhyDetail: form.fiveWhyDetail.value,
                carEmail: form.carEmail.value,
                carDeadline: form.carDeadline.value,
                statusCar: form.statusCar.value,
                reportFile: results.find(r => r.id === 'reportFile').data,
                carFile: results.find(r => r.id === 'carFile').data,
                fiveWhyFile: results.find(r => r.id === 'fiveWhyFile').data,
                // ข้อมูลอื่นๆ ใส่เพิ่มตามโครงสร้าง
                follow1: "", follow2: "", follow3: "", yokotenFile: "", yokotenDetail: ""
            };

            google.script.run.withSuccessHandler(() => {
                alert("บันทึกข้อมูลเรียบร้อยแล้ว!");
                form.reset();
                submitBtn.disabled = false;
                submitBtn.innerText = "Submit Report";
            }).processForm(formData);
        });
    });

    function loadDashboard() {
        const body = document.getElementById('dash-body');
        body.innerHTML = '<tr><td colspan="7" class="text-center">Loading...</td></tr>';
        
        google.script.run.withSuccessHandler(data => {
            body.innerHTML = "";
            // ตัด header ออก (แถวแรก)
            data.slice(1).forEach(row => {
                const tr = document.createElement('tr');
                const statusClass = row[14] === 'close' ? 'status-close' : 'status-open';
                tr.innerHTML = `
                    <td>${row[1] ? new Date(row[1]).toLocaleDateString() : '-'}</td>
                    <td>${row[2]}</td>
                    <td>${row[6]}</td>
                    <td><small>${row[5]}</small></td>
                    <td><span class="status-badge ${statusClass}">${row[14]}</span></td>
                    <td>${row[16]}</td>
                    <td><button class="btn btn-sm btn-outline-primary">View</button></td>
                `;
                body.appendChild(tr);
            });
        }).getDashboardData();
    }
</script>

