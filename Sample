ยินดีครับคุณ Yoyo ในฐานะ Full Stack Developer ผมได้ออกแบบระบบ **Audit Report TUV** โดยใช้ Google Apps Script (GAS) เชื่อมต่อกับ Google Sheets เป็นฐานข้อมูล และใช้โครงสร้าง UI ที่ทันสมัยแบบ Single Page Application (SPA) เพื่อให้ตอบโจทย์การทำงานในโรงงานและการจัดการข้อมูล Audit อย่างมืออาชีพครับ
### ขั้นตอนที่ 1: การเตรียม Database ใน Google Sheets
 1. สร้าง Google Sheets ใหม่ ตั้งชื่อว่า **Audit_Report_DB**
 2. ที่ Sheet1 ให้เปลี่ยนชื่อเป็น Data และสร้าง Header ในแถวแรก (Row 1) ดังนี้:
   * A1: Timestamp | B1: Audit_Data | C1: Plant | D1: Detail | E1: Report_Files | F1: Finding | G1: Dept_In_Charge | H1: CAR_Internal_File | I1: CAR_Internal_Detail | J1: Five_Why_File | K1: Five_Why_Detail | L1: CAR_Email | M1: CAR_Deadline | N1: CAR_Internal_Deadline | O1: Status_CAR_Internal | P1: Evidence_Deadline | Q1: Evidence_Status | R1: Follow_up_1 | S1: Follow_up_2 | T1: Follow_up_3 | U1: Yokoten_File | V1: Yokoten_Detail
 3. สร้าง Folder ใน Google Drive เพื่อเก็บไฟล์ที่อัปโหลด และจดจำ Folder ID ไว้
### ขั้นตอนที่ 2: โค้ดสำหรับระบบ (4 ไฟล์)
ให้คุณไปที่ Extensions > Apps Script แล้วสร้างไฟล์ดังนี้ครับ:
#### 1. Code.gs (Backend Logic)
```javascript
function doGet() {
  return HtmlService.createTemplateFromFile('index')
    .evaluate()
    .setTitle('Audit Report TUV System')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function include(filename) {
  return HtmlService.createHtmlOutputFromFile(filename).getContent();
}

// ฟังก์ชันบันทึกข้อมูลและจัดการไฟล์
function processForm(obj) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Data');
  const folderId = 'ใส่_FOLDER_ID_ที่นี่'; // แทนที่ด้วย ID ของโฟลเดอร์ใน Drive
  const folder = DriveApp.getFolderById(folderId);

  // ฟังก์ชันช่วยอัปโหลดไฟล์
  function uploadFile(fileData, fileName) {
    if (!fileData || fileData === "") return "";
    const blob = Utilities.newBlob(Utilities.base64Decode(fileData.split(",")[1]), fileData.split(";")[0].split(":")[1], fileName);
    const file = folder.createFile(blob);
    return file.getUrl();
  }

  const reportFileUrl = uploadFile(obj.reportFile, "Report_" + obj.auditDate);
  const carFileUrl = uploadFile(obj.carFile, "CAR_" + obj.auditDate);
  const fiveWhyFileUrl = uploadFile(obj.fiveWhyFile, "5Why_" + obj.auditDate);
  const yokotenFileUrl = uploadFile(obj.yokotenFile, "Yokoten_" + obj.auditDate);

  sheet.appendRow([
    new Date(),
    obj.auditDate,
    obj.plant,
    obj.detail,
    reportFileUrl,
    obj.finding.join(", "),
    obj.dept,
    carFileUrl,
    obj.carDetail,
    fiveWhyFileUrl,
    obj.fiveWhyDetail,
    obj.carEmail,
    obj.carDeadline,
    obj.carIntDeadline,
    obj.statusCar,
    obj.evidenceDeadline,
    obj.evidenceStatus,
    obj.follow1,
    obj.follow2,
    obj.follow3,
    yokotenFileUrl,
    obj.yokotenDetail
  ]);
  
  return "Success";
}

function getDashboardData() {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Data');
  return sheet.getDataRange().getValues();
}

